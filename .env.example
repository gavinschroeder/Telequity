# Copy this file to ".env" and fill in your own values.
# ".env" is git-ignored — never commit real keys.

# Census ACS API key — FREE, required for the real (non-demo) pipeline.
#   Sign up: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# FCC Broadband Data Collection API (OPTIONAL) — only if you pull broadband via
# the API instead of the downloaded "Summary by Geography" CSV. Needs an FCC
# account + generated token.
FCC_BDC_USERNAME=
FCC_BDC_TOKEN=

# FCC Socrata app token (OPTIONAL) — raises the complaint API rate limit.
# Complaints work without it.
FCC_SOCRATA_APP_TOKEN=

# OPTIONAL — also write the gold workbook into this synced folder (OneDrive /
# SharePoint) so Power BI auto-refreshes from it. Example (Mac):
#   /Users/you/Library/CloudStorage/OneDrive-<org>/Telequity
TELEQUITY_PUBLISH_DIR=

# OPTIONAL — if set, the pipeline uses an LLM to polish the analysis summaries
# (numbers stay computed/fixed). Leave blank to use the deterministic narrative.
ANTHROPIC_API_KEY=
