# Power BI Embedded — Azure service-principal credentials.
# Copy to "web/server/.env" and fill in. Never commit the real .env.
#
# See web/README.md for how to obtain each value.

# Azure AD tenant (Directory) ID
AZURE_TENANT_ID=

# Service principal (Azure AD app registration) client ID + secret
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=

# Power BI workspace ("group") ID that holds the published report
POWERBI_WORKSPACE_ID=

# The report ID to embed
POWERBI_REPORT_ID=

# Port the token server listens on (frontend dev proxy points here)
PORT=3001
