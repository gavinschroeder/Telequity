# Frontend (Vite) env. Copy to "web/.env".

# Embedding mode: "public" (Publish to web — default, no backend) or "secure"
# (service-principal token backend in web/server).
VITE_EMBED_MODE=public

# Publish-to-web embed URL from Power BI:
#   File -> Embed report -> Publish to web (public)  ->  copy the link
# Looks like: https://app.powerbi.com/view?r=eyJrIjoiXXXXXXXX...
VITE_PUBLISH_TO_WEB_URL=https://app.powerbi.com/view?r=eyJrIjoiZThkZjkzZmMtYTlmZi00OWJhLTk0NjEtOTI1MTQwNzU4YTdmIiwidCI6IjBkNGRhMGY4LTRhMzEtNGQ3Ni1hY2U2LTBhNjIzMzFlMWI4NCIsImMiOjF9

# --- Only used when VITE_EMBED_MODE=secure ---
VITE_EMBED_ENDPOINT=/api/embed-token
VITE_API_TARGET=http://localhost:3001
